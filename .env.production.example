# ===========================================
# Ticket Hub - Production Environment Config
# ===========================================
# Copy this file to .env.production and fill in your values
# NEVER commit .env.production to version control!

# ===========================================
# Server Configuration
# ===========================================
NODE_ENV=production
PORT=8081
HOST=0.0.0.0

# ===========================================
# Database (Huawei Cloud RDS PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://tickethub_user:YOUR_SECURE_PASSWORD@your-rds-endpoint.rds.myhuaweicloud.com:5432/tickethub
DB_PASSWORD=YOUR_SECURE_PASSWORD

# ===========================================
# Authentication
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-real-secret-at-least-32-characters-long
JWT_EXPIRY=7d

# ===========================================
# Payment Processing (Stripe)
# ===========================================
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
PAYMENT_TEST_MODE=false

# ===========================================
# WhatsApp Cloud API
# ===========================================
WHATSAPP_PROVIDER=meta_cloud
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_VERIFY_TOKEN=tickethub_whatsapp_2025
WHATSAPP_API_VERSION=v18.0

# ===========================================
# Facebook Messenger
# ===========================================
MESSENGER_PAGE_ID=your_page_id
MESSENGER_ACCESS_TOKEN=your_page_access_token
MESSENGER_VERIFY_TOKEN=tickethub_messenger_2025
MESSENGER_APP_ID=your_app_id
MESSENGER_APP_SECRET=your_app_secret

# ===========================================
# Twitter API v2
# ===========================================
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_ENVIRONMENT_NAME=production

# ===========================================
# Rate Limiting & Security
# ===========================================
MAX_REQUESTS_PER_MINUTE=60
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_MAX_ATTEMPTS=20
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_WINDOW_MS=900000
AUTH_LOCKOUT_CLEANUP_MS=300000
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_MAX_AGE_MS=86400000

# ===========================================
# Scraping Configuration
# ===========================================
SCRAPING_TIMEOUT=15000
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
CACHE_TTL=1800000
ACTIVE_SOURCES=SA Tourism Events,Events Central SA,SA Venues Events

# ===========================================
# Huawei Cloud OBS (Object Storage)
# ===========================================
OBS_BUCKET_NAME=tickethub-assets
OBS_ACCESS_KEY_ID=your_obs_access_key
OBS_SECRET_ACCESS_KEY=your_obs_secret_key
OBS_ENDPOINT=obs.myhuaweicloud.com
OBS_REGION=af-south-1

# ===========================================
# Logging & Monitoring
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_METRICS=true
ENABLE_LOG_MONITORING=false
ENABLE_AUTOMATIC_BACKUPS=false

# ===========================================
# Startup Controls
# ===========================================
ENABLE_DEV_SEED=false
ENABLE_TEST_USERS=false
ENABLE_DEFAULT_USERS=false
ENABLE_SCRAPER=false
BOOTSTRAP_ON_START=false

# ===========================================
# WebSocket Configuration
# ===========================================
WS_HEARTBEAT_INTERVAL=30000
WS_CONNECTION_TIMEOUT=60000

# ===========================================
# Email (Optional - for notifications)
# ===========================================
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@tickethub.com

# ===========================================
# Redis (Optional - for caching/sessions)
# ===========================================
REDIS_URL=redis://your-redis-endpoint:6379
REDIS_PASSWORD=your_redis_password
