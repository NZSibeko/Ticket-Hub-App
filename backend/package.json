{
  "name": "ticket-hub-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node ./server.ts",
    "build": "npm run check && tsc",
    "start": "node ./dist/server.js",
    "start:prod": "node ./dist/server.js",
    "bootstrap": "cross-env BOOTSTRAP_ON_START=true node ./dist/server.js --bootstrap-only",
    "bootstrap:dev": "cross-env BOOTSTRAP_ON_START=true ts-node ./server.ts --bootstrap-only",
    "check": "tsc --noEmit",
    "check:strict": "tsc --noEmit --pretty false",
    "test": "node --test ./tests/*.test.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "sqlite3": "^5.0.2",
    "uuid": "^13.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "cross-env": "^7.0.3",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
