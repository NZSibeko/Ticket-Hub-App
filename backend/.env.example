PAYMENT_TEST_MODE=true
STRIPE_SECRET_KEY=sk_test_your_key_here
JWT_SECRET=replace-with-strong-secret-at-least-32-characters-long
NODE_ENV=development
PORT=8081

# Scraping Configuration
SCRAPING_TIMEOUT=15000
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
CACHE_TTL=1800000

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=60
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_MAX_ATTEMPTS=20
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_WINDOW_MS=900000
AUTH_LOCKOUT_CLEANUP_MS=300000
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_MAX_AGE_MS=86400000

# Sources (comma separated)
ACTIVE_SOURCES=SA Tourism Events,Events Central SA,SA Venues Events

# WhatsApp Cloud API
WHATSAPP_PROVIDER=meta_cloud
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=replace-with-valid-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_VERIFY_TOKEN=tickethub_whatsapp_2025
WHATSAPP_API_VERSION=v18.0

# Messenger Configuration
MESSENGER_PAGE_ID=your_page_id
MESSENGER_ACCESS_TOKEN=your_page_access_token
MESSENGER_VERIFY_TOKEN=tickethub_messenger_2025
MESSENGER_APP_ID=your_app_id
MESSENGER_APP_SECRET=your_app_secret

# Twitter API v2 Configuration
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret
TWITTER_BEARER_TOKEN=your_bearer_token
TWITTER_ENVIRONMENT_NAME=development

# Startup controls
ENABLE_DEV_SEED=false
ENABLE_TEST_USERS=false
ENABLE_DEFAULT_USERS=false
ENABLE_SCRAPER=false
ENABLE_AUTOMATIC_BACKUPS=false
ENABLE_LOG_MONITORING=false
BOOTSTRAP_ON_START=true
