{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "rootDir": "./",
    "outDir": "./dist",
    "strict": true,
    "noCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "App.tsx",
    "App.web.tsx",
    "index.ts",
    "index.web.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "constants/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "backend",
    "scripts"
  ],
  "extends": "expo/tsconfig.base"
}
