   # TICKET-HUB APP - ENVIRONMENT TEMPLATE
   # Copy to .env and fill in real values

   # Server
   PORT=8081
   NODE_ENV=development

   # Security (CHANGE IN PRODUCTION!)
   JWT_SECRET=change-this-to-a-secu re-random-string
   JWT_EXPIRY=24h

   # Ngrok (Update when URL changes)
   NGROK_URL=https://your-url.ngrok-free.dev

   # WhatsApp
   WHATSAPP_VERIFY_TOKEN=tickethub_whatsapp_2025
   WHATSAPP_PHONE_NUMBER_ID=
   WHATSAPP_BUSINESS_ACCOUNT_ID=
   WHATSAPP_ACCESS_TOKEN=

   # Messenger
   MESSENGER_VERIFY_TOKEN=tickethub_messenger_2025
   MESSENGER_PAGE_ACCESS_TOKEN=

   # Twitter
   TWITTER_API_KEY=
   TWITTER_API_SECRET=
   TWITTER_BEARER_TOKEN=

   # Database
   DATABASE_PATH=./backend/tickethub.db

   # Stripe
   STRIPE_PUBLIC_KEY=
   STRIPE_SECRET_KEY=

   # CORS
   CORS_ORIGINS=http://localhost:3000,http://localhost:8081